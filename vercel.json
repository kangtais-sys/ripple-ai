{
  "crons": [
    {
      "path": "/api/cron/refresh-ig-token",
      "schedule": "0 3 * * 1"
    },
    {
      "path": "/api/cron/publish-scheduled",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/trend-research",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/refresh-recommendations",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/cron/beta-lifecycle",
      "schedule": "0 0 * * *"
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/landing.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/privacy", "destination": "/terms.html?tab=privacy" },
    { "source": "/app", "destination": "/app.html" }
  ],
  "redirects": [
    { "source": "/app.html", "destination": "/app", "permanent": true },
    { "source": "/landing.html", "destination": "/", "permanent": true },
    { "source": "/landing", "destination": "/", "permanent": true },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.ssobi.ai" }],
      "destination": "https://ssobi.ai/$1",
      "permanent": true
    }
  ]
}
